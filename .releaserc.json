{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/changelog", {
      "changelogFile": "CHANGELOG.md"
    }],
    ["@semantic-release/npm", {
      "npmPublish": false,
      "pkgRoot": "frontend"
    }],
    ["@semantic-release/exec", {
      "prepareCmd": "cd frontend && npx vite build && npx electron-builder --linux"
    }],
    ["@semantic-release/git", {
      "assets": ["CHANGELOG.md", "frontend/package.json"],
      "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
    }],
    ["@semantic-release/github", {
      "assets": [
        {
          "path": "frontend/release/*.AppImage",
          "label": "Core Keeper Armory (${nextRelease.version}) Linux"
        },
        {
          "path": "frontend/release/latest-linux.yml",
          "label": "Update Metadata (Linux)"
        }
      ]
    }]
  ]
}
